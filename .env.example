# Copy to .env and fill in. All VITE_* vars are PUBLIC — they get
# inlined into the built JS and are visible to anyone. Never put a
# secret key or password here.

# Mock mode: leave unset (or "true") to demo the UI without backends.
VITE_USE_MOCKS= "false"

# n8n webhooks
VITE_N8N_SIGNUP_URL=
VITE_N8N_LOGIN_URL=
# Fired right after login, in parallel — loads past sessions + plan
VITE_N8N_HISTORY_URL= 
VITE_N8N_MCQ_URL=https://primary-production-ba251.up.railway.app/webhook/generate-mcq
VITE_N8N_FLASHCARD_URL=https://primary-production-ba251.up.railway.app/webhook/generate-flashcards
VITE_N8N_CHAT_URL=https://primary-production-ba251.up.railway.app/webhook/rivision-chat
VITE_N8N_END_SESSION_URL=https://primary-production-ba251.up.railway.app/webhook/evaluate-session

# Study planner REST API
VITE_PLANNER_API_URL=

# Supabase (anon key only — requires Row Level Security to be ON)
VITE_SUPABASE_URL=https://mpcbgamgjiegmocsvmhd.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_-anumpzmGy_kZ6cSOt_C2Q_nCAMRYgS